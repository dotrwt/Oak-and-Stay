<% layout('layouts/boilerplate') -%>
<section class="home-hero">
    <div class="home-hero__text">
        <h1 style="font-family: 'Playfair Display', serif;">Oak and Stay</h1>
        <p class="lede">Discover unique stays and experiences. Play, relax, and explore handpicked rentals from our vibrant community.</p>
        <div class="hero-cta">
            <a class="btn btn-dark btn-lg" href="#listings">Browse Stays</a>
            <a class="btn btn-outline-dark btn-lg" href="/listings/new">Add a Listing</a>
        </div>
    </div>
    <div class="home-hero__media">
        <img src="https://images.unsplash.com/photo-1542314831-c6a4d1409362?auto=format&fit=crop&q=80&w=1000" alt="Beautiful Stay" class="home-slide-img w-100">
    </div>
</section>

<section class="page-header" id="listings" style="margin-top: 2rem;">
    <p class="eyebrow">Explore</p>
    <div class="page-header__actions">
        <div>
            <h2 class="page-title" style="font-family: 'Playfair Display', serif;">All Listings</h2>
        </div>
    </div>
</section>

<div class="card-grid">
    <% for (let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
            <article class="listing-card">
                <div class="listing-card__media">
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %> image">
                </div>
                <div class="listing-card__body">
                    <div>
                        <p class="listing-location"><%= listing.location %>, <%= listing.country %></p>
                        <h3><%= listing.title %></h3>
                    </div>
                    <p class="listing-price">₹<%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %> <span>/ night</span></p>
                </div>
            </article>
        </a>
    <% } %>
</div>
